# Model Maker Voice Agent — Environment Variables
# Copy this to .env and fill in your values

# ── OpenAI API Key (required for STT Whisper + TTS) ──
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Local LLM Server ──
# llama-cpp-python OpenAI-compatible endpoint (default: http://localhost:8001/v1)
LOCAL_LLM_BASE_URL=http://localhost:8001/v1
LOCAL_LLM_MODEL=llama-3.2-3b-medical

# ── LiveKit Server (dev mode defaults) ──
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
